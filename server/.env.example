# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pos_db

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# MQTT — local Mosquitto (docker-compose) OR EMQX Cloud (production)
#
# Local dev:
#   MQTT_BROKER_HOST=localhost
#   MQTT_BROKER_PORT=1883
#   MQTT_TLS_ENABLED=false
#
# EMQX Serverless (Europe region, TLS required):
#   Host + CA cert from EMQX Console → Deployment → Overview
#   Auth user from Access Control → Authentication
#   MQTT_BROKER_HOST=xxxxxx.emqxsl.com
#   MQTT_BROKER_PORT=8883
#   MQTT_BROKER_USERNAME=pos-server
#   MQTT_BROKER_PASSWORD=<from EMQX console>
#   MQTT_TLS_ENABLED=true
#   MQTT_TLS_CA_CERT_PATH=./certs/emqx-ca.crt
#   # Or paste PEM into MQTT_TLS_CA_CERT (no file mount — good for Render secrets)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_CLIENT_ID=pos-server
MQTT_TLS_ENABLED=false
MQTT_TLS_CA_CERT_PATH=
MQTT_TLS_CA_CERT=

# Clerk (get from clerk.com → your app → API Keys)
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
# First Clerk sign-in auto-creates user + tenant when no invite exists (set false for invite-only prod)
ALLOW_SELF_SERVICE_SIGNUP=true

# Cloudinary — required for product image upload
# Dashboard: GET /images/upload-params → signed upload to api.cloudinary.com
# Get from cloudinary.com console → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App
API_V1_PREFIX=/api/v1
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:8080"]

# Pairing
PAIRING_CODE_LENGTH=8
PAIRING_CODE_EXPIRY_MINUTES=15
PAIRING_SESSION_EXPIRE_HOURS=12
DEVICE_PAIRING_NONCE_EXPIRE_MINUTES=15
PAIRING_MOBILE_APP_BASE_URL=http://localhost:3002
MACHINE_TOKEN_EXPIRE_DAYS=365
PORT=8001
# Copy to .env.local for local development (overrides .env).
#   cp .env.local.example .env.local
# Start Postgres + Mosquitto:
#   docker compose up -d db mqtt
# Migrate + run:
#   cd server && poetry run alembic upgrade head
#   poetry run python run.py

# Database (docker-compose)
DATABASE_URL=postgresql://postgres:password@localhost:5432/pos_db

# MQTT (docker-compose Mosquitto)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_CLIENT_ID=pos-server
MQTT_TLS_ENABLED=false
MQTT_TLS_CA_CERT_PATH=
MQTT_TLS_CA_CERT=

# JWT
JWT_SECRET_KEY=change-me-local-dev-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Clerk (from clerk.com dashboard)
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
ALLOW_SELF_SERVICE_SIGNUP=true

# Cloudinary (optional for image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App
API_V1_PREFIX=/api/v1
DEBUG=true
PORT=8001
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:8080"]

# Pairing
PAIRING_CODE_LENGTH=8
PAIRING_CODE_EXPIRY_MINUTES=15
PAIRING_SESSION_EXPIRE_HOURS=12
DEVICE_PAIRING_NONCE_EXPIRE_MINUTES=15
PAIRING_MOBILE_APP_BASE_URL=http://localhost:3002
MACHINE_TOKEN_EXPIRE_DAYS=365
